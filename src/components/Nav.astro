---
import { siteConfig } from "../config/site";
---

<!-- MOBILE MENU OVERLAY -->
<div class="mobile-menu" id="mobileMenu">
	<button class="mobile-close" id="mobileclose">&#10005;</button>
	{siteConfig.navigation.map((item) => (
		<a href={item.href} onclick="closeMobile()">{item.title}</a>
	))}
	<div class="mobile-socials">
		<a href={siteConfig.author.instagram.url} target="_blank">{siteConfig.author.instagram.username}</a>
	</div>
</div>

<!-- MAIN NAV -->
<nav>
	<div class="nav-top">
		<a href="#" class="nav-logo">{siteConfig.author.name}</a>
		<div class="nav-center">
			{siteConfig.navigation.map((item) => (
				<a href={item.href}>{item.title}</a>
			))}
		</div>
		<div class="nav-right">
			<div class="nav-social">
				<a href={siteConfig.author.instagram.url} target="_blank" title="Instagram">
					<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
				</a>
			</div>
			<a href="#buy" class="nav-cta">Get the Book</a>
		</div>
		<button class="hamburger" id="hamburger" aria-label="Open menu">
		<span></span><span></span><span></span>
		</button>
	</div>
</nav>

<style>
nav {
  background: var(--navy);
  position: sticky; top: 0; z-index: 300;
  border-bottom: 4px solid var(--gold);
}
.nav-top {
  display: flex; align-items: center; justify-content: space-between;
  padding: .85rem 3rem;
}
.nav-logo {
  font-family: 'Baloo 2', cursive; font-size: 1.75rem; font-weight: 800;
  color: #fff; text-decoration: none;
  display: flex; align-items: center; gap: .5rem; flex-shrink: 0;
}
.logo-star { color: var(--gold); display: inline-block; animation: spin 7s linear infinite; font-size: 1.3rem; }
.nav-center {
  display: flex; align-items: center; gap: .25rem;
  flex: 1; justify-content: center; flex-wrap: nowrap;
}
.nav-center a {
  text-decoration: none; color: rgba(255,255,255,.8);
  font-weight: 700; font-size: .82rem;
  padding: .4rem .65rem; border-radius: 10px;
  transition: all .2s; white-space: nowrap; display: inline-block;
}
.nav-center a:hover { color: var(--gold); background: rgba(255,255,255,.08); transform: translateY(-2px); }
.nav-right { display: flex; align-items: center; gap: .75rem; flex-shrink: 0; }
.nav-social { display: flex; align-items: center; gap: .5rem; }
.nav-social a {
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(255,255,255,.1); color: rgba(255,255,255,.7);
  text-decoration: none; font-size: 1rem;
  transition: all .2s; border: 1.5px solid rgba(255,255,255,.15);
}
.nav-social a:hover { background: var(--gold); color: var(--navy); border-color: var(--gold); transform: scale(1.15) rotate(-5deg); }
.nav-cta {
  background: var(--gold); color: var(--navy) !important;
  padding: .5rem 1.1rem; border-radius: 50px;
  font-weight: 800; font-size: .85rem; white-space: nowrap;
  box-shadow: 0 4px 0 var(--gold-d);
  text-decoration: none; display: inline-block;
  transition: transform .15s, box-shadow .15s;
}
.nav-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 0 var(--gold-d); }

/* Hamburger */
.hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: .3rem; flex-shrink: 0; }
.hamburger span { display: block; width: 24px; height: 2.5px; background: #fff; border-radius: 3px; transition: all .3s; }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px,5.5px); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5.5px); }

/* Mobile overlay */
.mobile-menu {
  display: none; position: fixed; inset: 0; background: var(--navy);
  z-index: 400; flex-direction: column; align-items: center; justify-content: center;
  gap: 1.5rem; padding: 2rem;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  font-family: 'Baloo 2', cursive; font-size: 1.7rem; font-weight: 800;
  color: #fff; text-decoration: none; transition: color .2s, transform .2s; display: inline-block;
}
.mobile-menu a:hover { color: var(--gold); transform: scale(1.06); }
.mobile-socials { display: flex; gap: 1rem; margin-top: .5rem; }
.mobile-socials a {
  display: flex; align-items: center; gap: .4rem;
  color: rgba(255,255,255,.7); text-decoration: none;
  font-size: 1rem; font-weight: 700; padding: .4rem .9rem;
  border-radius: 50px; background: rgba(255,255,255,.1); transition: all .2s;
}
.mobile-socials a:hover { background: var(--gold); color: var(--navy); }
.mobile-close {
  position: absolute; top: 1.5rem; right: 2rem;
  background: none; border: none; color: rgba(255,255,255,.6);
  font-size: 2rem; cursor: pointer; transition: color .2s;
}
.mobile-close:hover { color: var(--gold); }

@media(max-width: 900px) {
  .nav-center, .nav-right .nav-cta, .nav-right .nav-social { display: none; }
  .hamburger { display: flex; }
}
</style>

<script>
const ham = document.getElementById('hamburger');
const menu = document.getElementById('mobileMenu');
const closeBtn = document.getElementById('mobileClose');
ham?.addEventListener('click', () => {
  menu?.classList.add('open');
  ham.classList.add('open');
  document.body.style.overflow = 'hidden';
});
closeBtn?.addEventListener('click', closeMobile);

function closeMobile() {
  menu?.classList.remove('open');
  ham?.classList.remove('open');
  document.body.style.overflow = '';
}
// Expose globally for onclick attributes in mobile menu links
(window as any).closeMobile = closeMobile;
</script>
