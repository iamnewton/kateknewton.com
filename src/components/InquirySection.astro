---
type Field = {
  type: 'text' | 'email' | 'number' | 'textarea' | 'select';
  name: string;
  label: string;
  placeholder?: string;
  required?: boolean;
  full?: boolean;
  options?: string[];
};

type InquiryForm = {
  id: string;
  icon: string;
  label: string;
  inquiryType: string;
  submitText: string;
  notice?: string;
  fields: Field[];
